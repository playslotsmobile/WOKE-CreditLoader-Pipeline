# ── QuickBooks ──────────────────────────────────────────
QB_CLIENT_ID=                # QuickBooks app client ID
QB_CLIENT_SECRET=            # QuickBooks app client secret
QB_REDIRECT_URI=             # OAuth redirect URI
QB_REFRESH_TOKEN=            # Obtained after OAuth flow
QB_REALM_ID=                 # Your QB company ID
QB_ENVIRONMENT=sandbox       # sandbox or production

# ── Telegram ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # Bot token from @BotFather
TELEGRAM_ADMIN_CHAT_ID=      # Admin group chat ID for failure alerts

# ── Play777 Portal (PENDING from Anthony) ──────────────
PLAY777_URL=
PLAY777_USERNAME=
PLAY777_PASSWORD=

# ── IConnect Portal (PENDING from Anthony) ─────────────
ICONNECT_URL=
ICONNECT_USERNAME=
ICONNECT_PASSWORD=

# ── Database ───────────────────────────────────────────
DATABASE_URL=                # Postgres connection string (Railway)

# ── App ────────────────────────────────────────────────
JWT_SECRET=                  # Secret for admin JWT tokens
PORT=3000
HEADLESS=true                # Set false to debug Playwright visually
